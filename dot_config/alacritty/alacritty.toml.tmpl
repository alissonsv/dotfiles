[general]
import = [
  "~/.config/alacritty/tokyo-night-theme.toml"
]

[env]
TERM = "xterm-256color"

[font]
{{- if eq .chezmoi.hostname "wind" }}
size = 8.0
{{ else }}
size = 10.0
{{ end }}

[font.normal]
family = "JetBrains Mono Nerd Font"

[[keyboard.bindings]]
key = "Return"
mods = "Shift"
chars = "\u001B\r"
